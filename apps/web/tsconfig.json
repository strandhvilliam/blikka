{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"],
      "@blikka/api/*": ["../../packages/api/src/*"],
      "@blikka/runtime": ["../../packages/runtime/src"],
      "@blikka/redis": ["../../packages/redis/src"],
      "@blikka/auth": ["../../packages/auth/src"],
      "@blikka/db": ["../../packages/db/src"],
      "@blikka/telemetry": ["../../packages/telemetry/src"],
      "@blikka/email": ["../../packages/email/src"],
      "@blikka/aws": ["../../packages/aws/src"],
      "@blikka/kv-store": ["../../packages/kv-store/src"],
      "@blikka/validation": ["../../packages/validation/src"],
      "@blikka/pubsub": ["../../packages/pubsub/src"],
      "@blikka/realtime": ["../../packages/realtime/src"],
      "@blikka/realtime/*": ["../../packages/realtime/src/*"],
      "@blikka/exif-parser": ["../../packages/exif-parser/src"],
      "@blikka/image-manipulation": ["../../packages/image-manipulation/src"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules"]
}
