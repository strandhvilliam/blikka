{
  "$schema": "https://json.schemastore.org/tsconfig",
  "include": ["src", "."],
  "compilerOptions": {
    "esModuleInterop": true,
    "incremental": false,
    "isolatedModules": true,
    "lib": ["es2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleDetection": "force",
    "moduleResolution": "Bundler",
    "target": "ES2022",
    "noUncheckedIndexedAccess": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "noEmit": true,
    "allowJs": true,
    "paths": {
      "@/*": ["./src/*"],
      "@blikka/kv-store": ["../../packages/kv-store/src"],
      "@blikka/aws": ["../../packages/aws/src"],
      "@blikka/db": ["../../packages/db/src"],
      "@blikka/validation": ["../../packages/validation/src"],
      "@blikka/telemetry": ["../../packages/telemetry/src"],
      "@blikka/pubsub": ["../../packages/pubsub/src"],
      "@blikka/realtime": ["../../packages/realtime/src"],
      "@blikka/task-runtime": ["../../packages/task-runtime/src"],
      "@blikka/uploads": ["../../packages/uploads/src"],
      "@blikka/uploads/*": ["../../packages/uploads/src/*"],
      "*": ["./*"]
    },
    "strict": true
  },
  "exclude": ["node_modules"]
}
