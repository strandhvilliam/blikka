{
  "compilerOptions": {
    // Environment setup & latest features
    "lib": ["ESNext"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "allowJs": true,

    // Bundler mode
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,

    // Best practices
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,

    // Some stricter flags (disabled by default)
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false,
    "paths": {
      "@blikka/db": ["../../packages/db/src"],
      "@blikka/auth": ["../../packages/auth/src"],
      "@blikka/email": ["../../packages/email/src"],
      "@blikka/redis": ["../../packages/redis/src"],
      "@blikka/s3": ["../../packages/s3/src"],
      "@blikka/kv-store": ["../../packages/kv-store/src"],
      "@blikka/pubsub": ["../../packages/pubsub/src"],
      "@blikka/validation": ["../../packages/validation/src"]
    }
  }
}
