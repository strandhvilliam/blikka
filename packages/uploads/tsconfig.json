{
  "compilerOptions": {
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "allowJs": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false,
    "paths": {
      "@blikka/aws": ["../../packages/aws/src"],
      "@blikka/db": ["../../packages/db/src"],
      "@blikka/email": ["../../packages/email/src"],
      "@blikka/image-manipulation": ["../../packages/image-manipulation/src"],
      "@blikka/kv-store": ["../../packages/kv-store/src"],
      "@blikka/redis": ["../../packages/redis/src"],
      "@blikka/validation": ["../../packages/validation/src"]
    }
  }
}
